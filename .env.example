# Authentication
ADMIN_PASSWORD=admin123
JWT_SECRET=change-me-to-a-long-random-string-in-production

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/meta_ads_crm_dev

# Application
NEXT_PUBLIC_BASE_URL=http://localhost:3000
LOG_LEVEL=info

# Meta Ads Integration
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret

# SendGrid Email Configuration
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@company.com
SENDGRID_FROM_NAME=Meta Ads CRM

# Twilio SMS Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1...

# Meta WhatsApp Configuration
META_WHATSAPP_API_KEY=your_meta_whatsapp_api_key
META_WHATSAPP_BUSINESS_ID=your_business_id
META_WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_WEBHOOK_TOKEN=your_webhook_verification_token

# Messaging Service Configuration
MESSAGE_SEND_BATCH_SIZE=100
MESSAGE_RETRY_MAX_ATTEMPTS=3
MESSAGE_RETRY_BACKOFF_MULTIPLIER=2

# Alerting Configuration
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
ALERT_EMAIL=your-email@example.com
